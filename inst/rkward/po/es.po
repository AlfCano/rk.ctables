msgid "Custom Tables (expss)"
msgstr "Tablas Personalizadas (expss)"

msgid "Custom Tables Builder"
msgstr "Constructor de Tablas Personalizadas"

msgid "Custom Tables (SPSS Style)"
msgstr "Tablas Personalizadas (Estilo SPSS)"

msgid "Create complex hierarchical tables with stacking and nesting logic using 'expss'. equivalent to SPSS CTABLES."
msgstr "Cree tablas jerárquicas complejas con lógica de apilamiento y anidación usando 'expss'. Equivalente a SPSS CTABLES."

msgid "Select Row variables (Stacked) and Column variables (Nested). Apply weights and select statistics."
msgstr "Seleccione las variables de Fila (Apiladas) y las variables de Columna (Anidadas). Aplique pesos y seleccione estadísticas."

msgid "Layout"
msgstr "Diseño"

msgid "Rows (Stacked Variables)"
msgstr "Filas (Variables Apiladas)"

msgid "Columns (Grouping/Nesting)"
msgstr "Columnas (Agrupación/Anidación)"

msgid "Weight Variable (Optional)"
msgstr "Variable de Ponderación (Opcional)"

msgid "Statistics"
msgstr "Estadísticas"

msgid "Select statistics to calculate:"
msgstr "Seleccione las estadísticas a calcular:"

msgid "Counts (Cases)"
msgstr "Recuentos (Casos)"

msgid "Column Percent %"
msgstr "Porcentaje de Columna %"

msgid "Row Percent %"
msgstr "Porcentaje de Fila %"

msgid "Options"
msgstr "Opciones"

msgid "Label for Total column"
msgstr "Etiqueta para la columna Total"

msgid "Total Position"
msgstr "Posición del Total"

msgid "Before (Left/Top)"
msgstr "Antes (Izquierda/Arriba)"

msgid "After (Right/Bottom)"
msgstr "Después (Derecha/Abajo)"

msgid "None"
msgstr "Ninguno"

msgid "Save table as"
msgstr "Guardar tabla como"
